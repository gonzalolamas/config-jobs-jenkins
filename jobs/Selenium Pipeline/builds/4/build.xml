    <script>pipeline {
    // 1. Definimos el agente donde va a correr
    agent any

    // 2. Herramientas: Cambiamos Gradle por Node.js
    tools {
        nodejs &quot;NodeJS&quot; // Nota: &quot;NodeJS&quot; debe ser el nombre exacto configurado en Administrar Jenkins -&gt; Global Tool Configuration
    }

    // 3. Etapas del Pipeline
    stages {
        stage(&quot;Tareas de limpieza e instalacion&quot;) {
            steps {
                
                // Le agregamos explícitamente branch: &apos;main&apos; antes de la URL
                git branch: &apos;main&apos;, url: &apos;https://github.com/gonzalolamas/mi-test-node-jenkins.git&apos;
        
                
                 
                // Clonamos tu repositorio de Node.js (puedes cambiarlo por tu URL)
                git &apos;https://github.com/gonzalolamas/mi-test-node-jenkins.git&apos;
                
                // En Node.js, para limpiar dependencias viejas o asegurar una instalación limpia:
                // Si estás en Windows usa &apos;bat&apos;, si estás en Linux/Mac usa &apos;sh&apos;
                bat &apos;npm clean-install&apos; 
                // Nota: También puedes usar &apos;bat npm ci&apos; o simplemente &apos;bat npm install&apos;
                
                 bat &apos;node app.js&apos;
            }
        }

        stage(&quot;Imprimo cositas&quot;) {
            steps {
                echo &quot;Soy un Stage aparte&quot;
                // Aquí podrías correr tu app si quisieras:
                // bat &apos;node app.js&apos;
            }
        }
    }
}</script>
